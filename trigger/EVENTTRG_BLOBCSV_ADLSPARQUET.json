{
	"name": "EVENTTRG_BLOBCSV_ADLSPARQUET",
	"properties": {
		"description": "Event trigger to move file from blob to adls as soon as the file is placed ",
		"annotations": [],
		"runtimeState": "Stopped",
		"pipelines": [
			{
				"pipelineReference": {
					"referenceName": "PY_TRIGGERS_EVENT",
					"type": "PipelineReference"
				},
				"parameters": {
					"pl_param_foldername": "@triggerBody().folderPath",
					"pl_param_filename": "@triggerBody().fileName"
				}
			}
		],
		"type": "BlobEventsTrigger",
		"typeProperties": {
			"blobPathBeginsWith": "/input-trigger/blobs/",
			"blobPathEndsWith": ".csv",
			"ignoreEmptyBlobs": true,
			"scope": "/subscriptions/11442715-cc46-49ec-b253-d92f9c67119e/resourceGroups/rg_dev_travel/providers/Microsoft.Storage/storageAccounts/blobstorage0728",
			"events": [
				"Microsoft.Storage.BlobCreated"
			]
		}
	}
}